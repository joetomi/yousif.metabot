# Flask configuration
SECRET_KEY=super-secret-key-change-me-in-production

# Meta Graph API settings
# Your Facebook App Secret (used to verify X-Hub-Signature-256)
APP_SECRET=your_meta_app_secret_here

# Page access token (must have pages_messaging, pages_read_engagement, pages_manage_metadata)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Verify token (must match the token you set when setting up webhooks in Meta Developer Console)
VERIFY_TOKEN=your_webhook_verify_token_here

# Page ID of the monitored Facebook page
PAGE_ID=your_page_id_here

# Base URL for the webhook (e.g. from localtunnel or ngrok)
TUNNEL_URL=https://ready-otters-happen.loca.lt

# Database configuration (defaults to local SQLite database)
DATABASE_URL=postgresql://postgres.smjtwrojbzkbfrlveywu:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
